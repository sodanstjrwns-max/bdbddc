{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2025-12-20",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "bdbddc-images"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bdbddc-production",
      "database_id": "bc30460e-c27f-43db-8644-2e3450f43b8d"
    }
  ]
}